#: app/helpers/check_target.py:28
msgid "This action cannot be performed."
msgstr "“이 명령어를 실행할 권한이 없습니다.”"

#: app/helpers/check_target.py:32
msgid "The server owner cannot be targeted."
msgstr "“서버 소유자는 대상이 될 수 없습니다.”"

#: app/helpers/check_target.py:36
msgid "This action cannot be performed on yourself."
msgstr "“자신에게 이 작업을 수행할 수 없습니다.”"

#: app/helpers/check_target.py:40
msgid "Bots cannot be targeted with this action."
msgstr "“봇은 이 작업의 대상이 될 수 없습니다.”"

#: app/helpers/check_target.py:49
msgid "My role must be higher than the target's role."
msgstr "“내 역할은 대상의 역할보다 높아야 합니다.”"

#: app/helpers/check_target.py:53
msgid "Your role must be higher than the target's role."
msgstr "“당신의 역할은 대상의 역할보다 높아야 합니다.”"

#: app/helpers/embed_factory.py:49
#, python-format
msgid "%(success_emoji)s Action Completed"
msgstr "%(success_emoji)s“작업 완료”"

#: app/helpers/embed_factory.py:63
#, python-format
msgid "%(error_emoji)s Action Failed"
msgstr "%(error_emoji)s“작업 실패”"

